{
  "name": "tcl-syntax",
  "displayName": "TCL Syntax",
  "description": "TCL language support with syntax highlighting and formatting",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "keywords": [
    "tcl",
    "tk",
    "expect"
  ],
  "publisher": "amos-anderson",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/tcl-vscode"
  },
  "activationEvents": [
    "onLanguage:tcl",
    "onDebugResolve:tcl",
    "onDebugInitialConfigurations"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "tcl",
        "aliases": [
          "TCL",
          "Tcl"
        ],
        "extensions": [
          ".tcl",
          ".tk",
          ".tm",
          ".test"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "tcl",
        "scopeName": "source.tcl",
        "path": "./syntaxes/tcl.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "TCL",
      "properties": {
        "tcl.format.alignBraces": {
          "type": "boolean",
          "default": true,
          "description": "Align opening and closing braces"
        },
        "tcl.format.spacesAroundOperators": {
          "type": "boolean",
          "default": true,
          "description": "Add spaces around operators"
        },
        "tcl.format.spacesInsideBraces": {
          "type": "boolean",
          "default": true,
          "description": "Add spaces inside braces"
        },
        "tcl.format.spacesInsideBrackets": {
          "type": "boolean",
          "default": false,
          "description": "Add spaces inside brackets"
        },
        "tcl.format.enable": {
          "type": "boolean",
          "default": false,
          "description": "Enable automatic TCL formatting on save"
        },
        "tcl.diagnostics.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable TCL syntax diagnostics"
        },
        "tcl.diagnostics.useTclsh": {
          "type": "boolean",
          "default": true,
          "description": "Use tclsh for advanced syntax validation"
        },
        "tcl.repl.tclPath": {
          "type": "string",
          "default": "tclsh",
          "description": "Path to TCL interpreter for REPL"
        },
        "tcl.test.tclPath": {
          "type": "string",
          "default": "tclsh",
          "description": "Path to TCL interpreter for running tests"
        },
        "tcl.interpreter.path": {
          "type": "string",
          "default": "tclsh",
          "description": "Path to the default TCL interpreter"
        },
        "tcl.interpreters.customPaths": {
          "type": "array",
          "default": [],
          "description": "Custom TCL interpreter paths"
        },
        "tcl.packages.autoDiscovery": {
          "type": "boolean",
          "default": true,
          "description": "Automatically discover TCL packages in workspace"
        }
      }
    },
    "commands": [
      {
        "command": "tcl.formatDocument",
        "title": "TCL: Format Document"
      },
      {
        "command": "tcl.startREPL",
        "title": "TCL: Start REPL"
      },
      {
        "command": "tcl.evaluateSelection",
        "title": "TCL: Evaluate Selection in REPL"
      },
      {
        "command": "tcl.runCurrentFile",
        "title": "TCL: Run Current File in REPL"
      },
      {
        "command": "tcl.runTests",
        "title": "TCL: Run Tests"
      },
      {
        "command": "tcl.generateCoverage",
        "title": "TCL: Generate Test Coverage"
      },
      {
        "command": "tcl.clearCoverage",
        "title": "TCL: Clear Coverage Data"
      },
      {
        "command": "tcl.exportCoverageReport",
        "title": "TCL: Export Coverage Report"
      },
      {
        "command": "tcl.extractProcedure",
        "title": "TCL: Extract Procedure"
      },
      {
        "command": "tcl.extractVariable",
        "title": "TCL: Extract Variable"
      },
      {
        "command": "tcl.inlineVariable",
        "title": "TCL: Inline Variable"
      },
      {
        "command": "tcl.selectInterpreter",
        "title": "TCL: Select Interpreter"
      },
      {
        "command": "tcl.addCustomInterpreter",
        "title": "TCL: Add Custom Interpreter"
      },
      {
        "command": "tcl.refreshInterpreters",
        "title": "TCL: Refresh Interpreters"
      },
      {
        "command": "tcl.createPackage",
        "title": "TCL: Create Package"
      },
      {
        "command": "tcl.updatePackageIndex",
        "title": "TCL: Update Package Index"
      },
      {
        "command": "tcl.newProject",
        "title": "TCL: New Project"
      },
      {
        "command": "tcl.installDependencies",
        "title": "TCL: Install Dependencies"
      },
      {
        "command": "tcl.updateDependencies",
        "title": "TCL: Update Dependencies"
      },
      {
        "command": "tcl.refreshDependencies",
        "title": "TCL: Refresh Dependencies"
      },
      {
        "command": "tcl.createDependencyReport",
        "title": "TCL: Create Dependency Report"
      },
      {
        "command": "tcl.runBuild",
        "title": "TCL: Run Build Task"
      }
    ],
    "debuggers": [
      {
        "type": "tcl",
        "label": "TCL Debug",
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Absolute path to a TCL file.",
                "default": "${workspaceFolder}/${command:AskForProgramName}"
              },
              "tclPath": {
                "type": "string",
                "description": "Path to TCL interpreter",
                "default": "tclsh"
              },
              "args": {
                "type": "array",
                "description": "Arguments passed to the program",
                "default": []
              },
              "cwd": {
                "type": "string",
                "description": "Working directory",
                "default": "${workspaceFolder}"
              },
              "env": {
                "type": "object",
                "description": "Environment variables",
                "default": {}
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Stop on entry",
                "default": true
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "tcl",
            "request": "launch",
            "name": "Launch TCL",
            "program": "${file}",
            "stopOnEntry": true
          }
        ],
        "configurationSnippets": [
          {
            "label": "TCL: Launch",
            "description": "A new configuration for launching a TCL program",
            "body": {
              "type": "tcl",
              "request": "launch",
              "name": "Launch TCL",
              "program": "^\"\\${workspaceFolder}/\\${command:AskForProgramName}\"",
              "stopOnEntry": true
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "dependencies": {
    "vscode-debugadapter": "^1.51.0",
    "vscode-debugprotocol": "^1.51.0"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "@vscode/test-electron": "^2.2.0",
    "eslint": "^8.28.0",
    "glob": "^11.0.3",
    "mocha": "^11.7.1",
    "typescript": "^4.9.3"
  }
}
